# ============================================================
# Backend 환경변수 (.env.example → 복사 후 .env로 사용)
# ============================================================

# PostgreSQL 연결 문자열
DATABASE_URL="postgresql://postgres:password@localhost:5432/videodb"

# 서버 포트
PORT=4000

# 서버 공개 URL (QR 코드에 삽입될 주소)
BASE_URL="http://localhost:4000"

# 프론트엔드 CORS 허용 URL
FRONTEND_URL="http://localhost:5173"
